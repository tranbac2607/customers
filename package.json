{
  "name": "customers",
  "version": "1.0.0",
  "private": true,
  "description": "Customer Management Web App - Full-stack assignment (Next.js + Express + MongoDB)",
  "workspaces": [
    "back-end",
    "front-end"
  ],
  "scripts": {
    "lint": "npm-run-all -p lint:be lint:fe",
    "lint:be": "npm --workspace back-end run lint",
    "lint:fe": "npm --workspace front-end run lint",
    "typecheck": "npm-run-all -p typecheck:be typecheck:fe",
    "typecheck:be": "npm --workspace back-end run typecheck",
    "typecheck:fe": "npm --workspace front-end run typecheck",
    "test": "npm --workspace back-end run test",
    "build": "npm-run-all -p build:be build:fe",
    "build:be": "npm --workspace back-end run build",
    "build:fe": "npm --workspace front-end run build",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "dev:be": "npm --workspace back-end run dev:memory",
    "dev:fe": "npm --workspace front-end run dev",
    "seed": "npm --workspace back-end run seed:memory"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
